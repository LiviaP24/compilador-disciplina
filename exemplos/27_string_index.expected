int main(void) {
        char * t1;
        int t2;
        int t3;
        int t4;
        int t5;
        char t6;
        char t7;

        t2 = 4;
        t3 = sizeof(char);
        t4 = t2 * t3;
        t1 = (char*) malloc(t4);
        strcpy(t1, "abc");
